# MySQL (matches Prisma schema). Example:
# DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/apartment_management"
#
# Cloud MySQL (e.g. Aiven) on Windows: TLS errors → set MYSQL_TLS_INSECURE=true (dev only).
# For `npx prisma migrate`, PowerShell: $env:NODE_TLS_REJECT_UNAUTHORIZED="0"; npx prisma migrate dev
DATABASE_URL="mysql://root:password@localhost:3306/apartment_management"
MYSQL_TLS_INSECURE=false

# Login lockout (optional): after N failed attempts per email, block for M minutes
# LOGIN_MAX_FAILURES=5
# LOGIN_LOCKOUT_MINUTES=3

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe (optional - for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

// Apartment Management — MySQL schema aligned with users table:
// id, name, email, password, phone_number, role (admin|landlord|tenant), created_at
// Plus app fields: room_id, is_active, temp_password, updated_at, last_login_at

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  landlord
  tenant
  maintenance
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  password     String    @db.VarChar(255)
  phoneNumber  String?   @map("phone_number") @db.VarChar(20)
  role         UserRole
  roomId       String?   @map("room_id")
  isActive     Boolean   @default(true) @map("is_active")
  tempPassword Boolean   @default(false) @map("temp_password")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  room                  Room?                 @relation(fields: [roomId], references: [id])
  maintenanceRequests   MaintenanceRequest[]
  payments              Payment[]
  notifications         Notification[]
  leases                Lease[]
  auditLogs             AuditLog[]
  supportChats          SupportChat[]

  @@map("users")
}

model Building {
  id          String   @id @default(cuid())
  name        String
  address     String
  description String?
  facilities  String
  images      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rooms Room[]
}

model Room {
  id              String   @id @default(cuid())
  buildingId      String   @map("building_id")
  roomNumber      String   @map("room_number")
  floor           Int?
  capacity        Int
  monthlyRent     Float    @map("monthly_rent")
  isAvailable     Boolean  @default(true) @map("is_available")
  maintenanceMode Boolean  @default(false) @map("maintenance_mode")
  amenities       String
  images          String
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  building              Building               @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenants               User[]
  payments              Payment[]
  maintenanceRequests   MaintenanceRequest[]
  leases                Lease[]
  bookings              Booking[]

  @@unique([buildingId, roomNumber])
}

model Payment {
  id         String    @id @default(cuid())
  userId     Int       @map("user_id")
  roomId     String    @map("room_id")
  amount     Float
  dueDate    DateTime  @map("due_date")
  paidDate   DateTime? @map("paid_date")
  status     String    @default("PENDING")
  lateFee    Float?    @map("late_fee")
  method     String?
  proofUrl   String?   @map("proof_url")
  receiptUrl String?   @map("receipt_url")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  month      Int
  year       Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model MaintenanceRequest {
  id          String        @id @default(cuid())
  userId      Int           @map("user_id")
  roomId      String        @map("room_id")
  title       String
  description String
  imageUrl    String?       @map("image_url")
  status      String        @default("PENDING")
  adminReply  String?       @map("admin_reply")
  completedAt DateTime?     @map("completed_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lease {
  id          String    @id @default(cuid())
  userId      Int       @map("user_id")
  roomId      String    @map("room_id")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  documentUrl String?   @map("document_url")
  signedAt    DateTime? @map("signed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Booking {
  id           String        @id @default(cuid())
  email        String
  name         String
  phone        String?
  roomId       String        @map("room_id")
  checkInDate  DateTime      @map("check_in_date")
  checkOutDate DateTime      @map("check_out_date")
  bookingFee   Float         @map("booking_fee")
  status       String        @default("PENDING")
  paymentProof String?       @map("payment_proof")
  adminNotes   String?       @map("admin_notes")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  address   String?
  gender    String?
  age       Int?
  photoUrl  String?  @map("photo_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    Int?     @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
}

model SiteSettings {
  id           String   @id @default(cuid())
  contactEmail String   @map("contact_email")
  contactPhone String   @map("contact_phone")
  mapEmbedUrl  String?  @map("map_embed_url") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model SupportChat {
  id         String   @id @default(cuid())
  userId     Int      @map("user_id")
  message    String
  senderRole String   @map("sender_role")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
